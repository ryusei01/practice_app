# Supabase (新しいAPI Keys方式)
# Settings → API Keys で作成
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # Publishable key
SUPABASE_SERVICE_KEY=sbsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # Secret key (Full Access)

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# JWT
SECRET_KEY=your-secret-key-here-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# generate_dev_token.py 用（省略時のユーザー UUID。任意）
# DEV_JWT_USER_ID=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Dashboard → Webhooks → エンドポイント URL: https://<API>/api/v1/subscriptions/webhook
# イベント: checkout.session.completed, payment_intent.succeeded
STRIPE_WEBHOOK_SECRET=whsec_...
PLATFORM_FEE_PERCENT=20
# 旧年額プラン互換の Price ID。未移行環境では年額として扱います
STRIPE_PREMIUM_PRICE_ID=price_...
# Checkout の行項目名は Stripe Dashboard の Product 名。ブランド変更時は月額/年額の Product 名を APP_DISPLAY_NAME に合わせて更新（Price ID はそのまま）。
# 月額 / 年額プランの Price ID（請求額は Stripe の Price に合わせる。月額200円キャンペーン時は Dashboard で 200 円の Price を作成して指定）
# STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_...
# STRIPE_PREMIUM_YEARLY_PRICE_ID=price_...
# 表示・付与クレジット（円）
# PREMIUM_MONTHLY_PRICE_JPY=200
# PREMIUM_MONTHLY_CREDIT_JPY=0
# PREMIUM_YEARLY_CREDIT_JPY=0
# キャンペーン表示用（取り消し線）。不要なら未設定またはコードの Optional を None に
# PREMIUM_MONTHLY_STRIKETHROUGH_PRICE_JPY=350
# PREMIUM_MONTHLY_STRIKETHROUGH_CREDIT_JPY=100

# App（APP_NAME は API 識別・OpenAPI。ユーザー向け表記は APP_DISPLAY_NAME）
APP_NAME=QuizMarketplace
APP_DISPLAY_NAME=AI Tangocho
DEBUG=True

# Email / SMTP (2段階認証用)
# Gmail の場合: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# Gmailアプリパスワードの作成: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@yourdomain.com

# CORS設定
# 開発環境: すべて許可
CORS_ORIGINS=*
# 本番環境: 特定のドメインのみ許可（カンマ区切りで複数指定可能）
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://yourdomain.pages.dev
# 列挙漏れ対策: ai-practice-book.com / *.aipracticebook.pages.dev を正規表現で追加許可（既定 true）
# CORS_ALLOW_PRODUCT_ORIGIN_REGEX=false

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# リバースプロキシ背後でレート制限 IP を X-Forwarded-For から取る（本番で Cloudflare/Render 経由なら true）
# TRUST_X_FORWARDED_FOR=false
# OAuth 連続失敗の一時ブロック（未設定で無効）
# REDIS_URL=redis://localhost:6379/0
# OAUTH_FAIL_THRESHOLD=7
# OAUTH_FAIL_WINDOW_SEC=900
# OAUTH_BLOCK_DURATION_SEC=900
# 問題 CSV 一括アップロード上限（バイト、既定 5242880）
# BULK_CSV_MAX_BYTES=5242880

# ML機能フラグ
# 本番 (Cloud Run) では false に設定してメモリ節約
# 開発環境では true のままで OK
ENABLE_ML=true

# クラウド LLM（学習プラン・著作権チェック・画像/テキストから問題生成）
# 優先順: Gemini → Hugging Face Inference（router）→ Groq。無料枠切れ時は下位へフォールバック。
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_VISION_MODEL=gemini-2.0-flash
# HF_TOKEN=                    # Hugging Face トークン（Inference Providers 用）
# HF_CHAT_MODEL=meta-llama/Llama-3.2-3B-Instruct:fastest
# HF_VISION_MODEL=llava-hf/llava-1.5-7b-hf:fastest
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_VISION_MODEL=llama-3.2-11b-vision-preview

# Ollama（オプション・ローカル翻訳のみ USE_LOCAL_TRANSLATION=true のとき）
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_TRANSLATION_MODEL=llama3.2:1b

# ---- Cloud Run / GitHub Actions 用 GitHub Secrets 一覧 ----
# 以下を GitHub の Settings → Secrets and variables → Actions に登録してください:
#
# GCP_SA_KEY          ... gcloud iam service-accounts keys create で生成した JSON の内容
# GCP_PROJECT_ID      ... GCP プロジェクトID（例: quiz-marketplace-prod）
# SUPABASE_URL
# SUPABASE_KEY
# SUPABASE_SERVICE_KEY
# DATABASE_URL
# SECRET_KEY
# STRIPE_SECRET_KEY
# STRIPE_PUBLISHABLE_KEY
# STRIPE_WEBHOOK_SECRET
# STRIPE_PREMIUM_PRICE_ID
# SMTP_USER
# SMTP_PASSWORD
# GOOGLE_CLIENT_ID
# CORS_ORIGINS        ... 本番フロントエンドのURL（例: https://aipracticebook.pages.dev）
