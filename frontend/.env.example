# API Backend URL
# 開発環境
EXPO_PUBLIC_API_URL=http://127.0.0.1:8003/api/v1

# 本番環境の例（実際のバックエンドURLに置き換える）
# EXPO_PUBLIC_API_URL=https://your-backend.railway.app/api/v1

# Google OAuth（Google Cloud Console で取得）
# https://console.cloud.google.com → APIとサービス → 認証情報 → OAuth 2.0 クライアントID
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
